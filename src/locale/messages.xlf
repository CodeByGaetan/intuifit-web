          <context context-type="linenumber">61,62</context>
        </context-group>
      </trans-unit>
      <trans-unit id="privacy.s7.p1" datatype="html">
        <source>If you contact support, we process your <x id="START_TAG_STRONG" ctype="x-strong" equiv-text="&lt;strong&gt;"/>email address and the content of your message<x id="CLOSE_TAG_STRONG" ctype="x-strong" equiv-text="&lt;/strong&gt;"/> for the sole purpose of answering you (legal basis: our legitimate interest in providing support, Art. 6(1)(f) GDPR). Support emails are kept only as long as needed to resolve your request, and no longer than <x id="START_TAG_STRONG" ctype="x-strong" equiv-text="&lt;strong&gt;"/>two years<x id="CLOSE_TAG_STRONG" ctype="x-strong" equiv-text="&lt;/strong&gt;"/>, then deleted.</source>
        <context-group purpose="location">
          <context context-type="sourcefile">src/app/pages/privacy/privacy.html</context>
          <context context-type="linenumber">62,64</context>
        </context-group>

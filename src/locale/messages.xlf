          <context context-type="linenumber">69,70</context>
        </context-group>
      </trans-unit>
      <trans-unit id="privacy.s8.p1" datatype="html">
        <source>This website is edited by Gaétan La Selve as a private individual, and hosted on <x id="START_TAG_STRONG" ctype="x-strong" equiv-text="&lt;strong&gt;"/>GitHub Pages<x id="CLOSE_TAG_STRONG" ctype="x-strong" equiv-text="&lt;/strong&gt;"/>, operated by GitHub, Inc., 88 Colin P. Kelly Jr Street, San Francisco, CA 94107, USA. Like any web host, GitHub may log visitors&apos; IP addresses for security and operational purposes; see <x id="START_LINK" ctype="x-a" equiv-text="&lt;a href=&quot;https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement&quot; target=&quot;_blank&quot; rel=&quot;noopener&quot;&gt;"/>GitHub&apos;s privacy statement<x id="CLOSE_LINK" ctype="x-a" equiv-text="&lt;/a&gt;"/>.</source>
        <context-group purpose="location">
          <context context-type="sourcefile">src/app/pages/privacy/privacy.html</context>
          <context context-type="linenumber">70,71</context>
        </context-group>
      </trans-unit>
      <trans-unit id="privacy.s8.p2" datatype="html">
        <source>The website itself sets <x id="START_TAG_STRONG" ctype="x-strong" equiv-text="&lt;strong&gt;"/>no cookies<x id="CLOSE_TAG_STRONG" ctype="x-strong" equiv-text="&lt;/strong&gt;"/>, runs <x id="START_TAG_STRONG" ctype="x-strong" equiv-text="&lt;strong&gt;"/>no analytics<x id="CLOSE_TAG_STRONG" ctype="x-strong" equiv-text="&lt;/strong&gt;"/>, and loads <x id="START_TAG_STRONG" ctype="x-strong" equiv-text="&lt;strong&gt;"/>no third-party resources<x id="CLOSE_TAG_STRONG" ctype="x-strong" equiv-text="&lt;/strong&gt;"/> — fonts are self-hosted, so no request is sent to font providers.</source>
        <context-group purpose="location">
          <context context-type="sourcefile">src/app/pages/privacy/privacy.html</context>
          <context context-type="linenumber">71,73</context>
        </context-group>
